# Secrets for the self-hosted Langfuse v3 stack (deploy/langfuse/docker-compose.yml).
# Copy to .env in this same directory: `cp .env.example .env`
# The example values below were generated for local/learning use only — regenerate
# them (same commands) before using this stack anywhere reachable off your machine.

# --- Core app secrets ---
# openssl rand -base64 32
NEXTAUTH_SECRET=+EV+uIPjr8zP9ceKT3zA0nswVCPBD1Ch6phmtfokdMs=
SALT=eg/lpSGeYcfno7EU9kXoP5RLVrRhY/+iD5aF0tGXqlo=
# openssl rand -hex 32  (must be exactly 64 hex chars)
ENCRYPTION_KEY=2d76f2893daa7c61e2422a0526e2482fb7b06aec640cef859ba092cae5bef52d

# --- Datastore passwords ---
# CLICKHOUSE_PASSWORD and REDIS_AUTH are read by the same variable name on
# both the datastore container and langfuse-web/-worker, so setting them once
# here is enough. POSTGRES_PASSWORD and MINIO_ROOT_PASSWORD are NOT auto-shared
# -- langfuse-web/-worker authenticate via separate variables (DATABASE_URL's
# embedded password, and the LANGFUSE_S3_*_SECRET_ACCESS_KEY vars below), which
# must be kept in sync with these by hand.
POSTGRES_PASSWORD=6ad9f14b8237fefbb393751b
CLICKHOUSE_PASSWORD=24f76a6d3f45da2dcaf41abb
MINIO_ROOT_PASSWORD=4694a3b6728f92fc847b22e6
# openssl rand -hex 16
REDIS_AUTH=c1a652642d1fb092c31ab52d0947caa7

# Must embed the same password as POSTGRES_PASSWORD above.
DATABASE_URL=postgresql://postgres:6ad9f14b8237fefbb393751b@postgres:5432/postgres
# Must match MINIO_ROOT_PASSWORD above (access key id stays "minio", the
# MINIO_ROOT_USER/LANGFUSE_S3_*_ACCESS_KEY_ID default that we never changed).
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=4694a3b6728f92fc847b22e6
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=4694a3b6728f92fc847b22e6
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=4694a3b6728f92fc847b22e6

# --- Auto-init: creates org/project/user/API-key on first boot, no UI signup ---
# (see docs/adr/0001-self-hosted-langfuse-tracing.md)
LANGFUSE_INIT_ORG_ID=minicode
LANGFUSE_INIT_ORG_NAME=minicode
LANGFUSE_INIT_PROJECT_ID=minicode-tracing
LANGFUSE_INIT_PROJECT_NAME=minicode-tracing
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-805abe22f0e9ee83f9a1f25dd168c69d
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-2428813910201d7f30cd9d6b05f3b6b4
LANGFUSE_INIT_USER_EMAIL=admin@minicode.local
LANGFUSE_INIT_USER_NAME=minicode-admin
LANGFUSE_INIT_USER_PASSWORD=84vDZJev3cdk8yxis3fuN7XS

# These two must match the PUBLIC/SECRET key pair above — copy them into the
# repo root .env so minicode's tracing.py can authenticate against this stack.
# LANGFUSE_PUBLIC_KEY=pk-lf-805abe22f0e9ee83f9a1f25dd168c69d
# LANGFUSE_SECRET_KEY=sk-lf-2428813910201d7f30cd9d6b05f3b6b4
# LANGFUSE_HOST=http://localhost:3000
